  "devDependencies": {
    "@einui/eslint-config": "workspace:*",
    "@einui/typescript-config": "workspace:*",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.6",
    "@types/node": "^25.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^28.1.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "eslint": "^9.39.2"
