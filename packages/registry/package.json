{
  "name": "@einui/registry",
  "version": "1.0.0",
  "private": true,
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./liquid-glass": "./src/liquid-glass/index.ts",
    "./liquid-glass/*": "./src/liquid-glass/*",
    "./innovative": "./src/innovative/index.ts",
    "./innovative/*": "./src/innovative/*",
    "./widgets": "./src/widgets/index.ts",
    "./widgets/*": "./src/widgets/*",
    "./blocks/*": "./src/blocks/*"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "dependencies": {
    "@einui/ui": "workspace:*",
    "@einui/utils": "workspace:*",
    "@einui/hooks": "workspace:*",
    "@radix-ui/react-accordion": "^1.2.13",
    "@radix-ui/react-alert-dialog": "^1.1.16",
    "@radix-ui/react-avatar": "^1.1.12",
    "@radix-ui/react-checkbox": "^1.3.4",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-label": "^2.1.9",
    "@radix-ui/react-popover": "^1.1.16",
    "@radix-ui/react-progress": "^1.1.9",
    "@radix-ui/react-radio-group": "^1.3.9",
    "@radix-ui/react-scroll-area": "^1.2.11",
    "@radix-ui/react-select": "^2.2.7",
    "@radix-ui/react-separator": "^1.1.9",
    "@radix-ui/react-slider": "^1.3.7",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-switch": "^1.2.7",
    "@radix-ui/react-tabs": "^1.1.14",
    "@radix-ui/react-tooltip": "^1.2.9",
    "class-variance-authority": "^0.7.1",
    "lucide-react": "^0.575.0",
    "framer-motion": "^12.34.3",
    "react": "19.2.7",
    "react-dom": "19.2.7"
